{
  "name": "handprint-sh",
  "version": "0.6.0",
  "type": "module",
  "description": "Capture human decision provenance from your AI coding transcripts. Runs entirely on your machine, no account required.",
  "keywords": [
    "ai",
    "provenance",
    "decisions",
    "transcripts",
    "claude-code",
    "opencode",
    "cli",
    "handprint",
    "local-llm",
    "attribution"
  ],
  "homepage": "https://github.com/CameronWhiteside/handprint#readme",
  "bugs": {
    "url": "https://github.com/CameronWhiteside/handprint/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CameronWhiteside/handprint.git"
  },
  "license": "Apache-2.0",
  "author": "Cameron Whiteside",
  "workspaces": [
    "packages/*"
  ],
  "bin": {
    "handprint": "./dist/bin/handprint.js"
  },
  "files": [
    "dist/bin/",
    "skills/",
    "README.md",
    "AGENTS.md",
    "CHANGELOG.md",
    "LICENSE",
    "NOTICE",
    "COVENANT.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "npm run build && npx tsc --noEmit && npm test",
    "test": "vitest run",
    "test:watch": "vitest",
    "handprint": "tsx bin/handprint.ts",
    "lint:unused": "knip",
    "lint": "tsc --noEmit && knip",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@noble/ciphers": "^2.2.0",
    "@noble/ed25519": "^3.1.0",
    "@noble/hashes": "^2.2.0",
    "commander": "^14.0.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "@vitest/coverage-v8": "^4.1.9",
    "knip": "^6.22.0",
    "node-llama-cpp": "^3.0.0",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
