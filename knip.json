{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "workspaces": {
    ".": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts", "bin/**/*.ts"]
    },
    "packages/types": {
      "project": ["src/**/*.ts"]
    }
  },
  "ignoreDependencies": ["@handprint/types"],
  "ignoreBinaries": ["claude"]
}
